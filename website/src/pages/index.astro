<script is:inline>
  function responsive() {
    var w = window.innerWidth;
    document.querySelectorAll('[data-cols]').forEach(function (el) {
      var d = el.getAttribute('data-cols');
      var m = el.getAttribute('data-cols-mid');
      if (w < 760) el.style.gridTemplateColumns = '1fr';
      else if (m && w < 1040) el.style.gridTemplateColumns = m;
      else el.style.gridTemplateColumns = d;
    });
    var nav = document.querySelector('[data-nav-links]');
    if (nav) nav.style.display = w < 860 ? 'none' : 'flex';
  }

  function setupHover() {
    document.querySelectorAll('[data-hover]').forEach(function (el) {
      var hoverText = el.getAttribute('data-hover');
      var base = el.getAttribute('style') || '';
      el.addEventListener('mouseenter', function () {
        el.setAttribute('style', base + ';' + hoverText);
      });
      el.addEventListener('mouseleave', function () {
        el.setAttribute('style', base);
      });
    });
  }

  function setupReveal() {
    var els = document.querySelectorAll('[data-reveal]');
    requestAnimationFrame(function () {
      els.forEach(function (e) {
        var d = parseInt(e.getAttribute('data-delay') || '0', 10);
        e.style.animation = 'tmReveal .7s ease both';
        e.style.animationDelay = (d / 1000) + 's';
      });
    });
  }

  function renderQR() {
    var el = document.getElementById('tm-qr');
    if (!el) return;
    var url = 'https://demo.tonymenu.app';
    var tries = 0;
    (function go() {
      if (window.QRCode) {
        el.innerHTML = '';
        new window.QRCode(el, {
          text: url, width: 200, height: 200,
          colorDark: '#241c16', colorLight: '#ffffff',
          correctLevel: window.QRCode.CorrectLevel.M
        });
      } else if (tries++ < 40) {
        setTimeout(go, 150);
      }
    })();
  }

  responsive();
  setupHover();
  setupReveal();
  renderQR();
  window.addEventListener('resize', responsive);
</script>

</body>
</html>
