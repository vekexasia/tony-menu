{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "dev:demo": "NEXT_PUBLIC_API_URL=https://api.tonymenu.app NEXT_PUBLIC_CHAT_WORKER_URL=https://risto-menu-demo-chat.vekexasia.workers.dev NEXT_PUBLIC_DEFAULT_LOCALE=en next dev --turbopack",
    "build": "next build",
    "build:cf": "next build",
    "preview:cf": "npx wrangler pages dev out",
    "deploy:cf": "set -a; [ -f .env.production.local ] && . ./.env.production.local; set +a; NEXT_PUBLIC_COMMIT_SHA=${NEXT_PUBLIC_COMMIT_SHA:-$(git rev-parse HEAD)} npm run build:cf && npx wrangler pages deploy out --project-name=${CF_PAGES_PROJECT:-menu} --branch=${CF_PAGES_BRANCH:-main}",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:live": "playwright test --config=playwright.live.config.ts",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "worker:dev": "cd workers/chat && npx wrangler dev",
    "worker:deploy": "cd workers/chat && npx wrangler deploy"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@headlessui/react": "^2.2.9",
    "@hookform/resolvers": "^5.2.2",
    "@menu/schemas": "*",
    "clsx": "^2.1.1",
    "country-flag-icons": "^1.6.16",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.25.0",
    "next": "^16.1.1",
    "next-intl": "^4.7.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.70.0",
    "react-intersection-observer": "^10.0.0",
    "tailwind-merge": "^3.4.0",
    "tinyld": "^1.3.4",
    "zod": "^4.3.5",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.0.0",
    "@playwright/test": "^1.57.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5.1.2",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^9",
    "eslint-config-next": "15.5.9",
    "jsdom": "^27.4.0",
    "playwright": "^1.57.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.0.16",
    "wrangler": "^4.53.0"
  }
}
