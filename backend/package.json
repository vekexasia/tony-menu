{
  "name": "backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --persist-to .wrangler/state",
    "deploy": "wrangler deploy --var COMMIT_SHA:${COMMIT_SHA:-$(git rev-parse HEAD)}",
    "check": "tsc --noEmit",
    "typegen": "wrangler types",
    "import:backup": "tsx scripts/import-from-backup.ts",
    "import:backup:dry": "tsx scripts/import-from-backup.ts --dry-run",
    "import:backup:local": "tsx scripts/import-from-backup.ts --local",
    "seed:local": "tsx scripts/seed-local.ts",
    "seed:demo": "tsx scripts/seed-from-demo.ts",
    "chat:sessions": "tsx scripts/download-chat-sessions.ts",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:migration-sql": "grep -E 'CREATE TYPE|jsonb|timestamp with time|numeric\\(' drizzle/*.sql 2>/dev/null && echo 'FAIL: postgres-isms found' && exit 1 || echo 'PASS: SQLite-only SQL'"
  },
  "dependencies": {
    "@menu/schemas": "*",
    "@types/better-sqlite3": "^7.6.13",
    "better-sqlite3": "^12.9.0",
    "drizzle-orm": "^0.43.1",
    "hono": "^4.10.1",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250411.0",
    "@types/node": "^22.15.3",
    "@vitest/coverage-v8": "^4.1.4",
    "drizzle-kit": "^0.31.4",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3",
    "vitest": "^4.1.4",
    "wrangler": "^4.53.0"
  }
}
