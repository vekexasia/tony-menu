# Copy this file to wrangler.toml and fill in the values for your deployment.
# wrangler.toml is gitignored — keep your real IDs out of source control.
#
# See docs/self-hosting.md for the full bootstrap walkthrough.

name = "menu-backend"
main = "src/index.ts"
compatibility_date = "2025-04-11"

[vars]
APP_ENV = "development"
API_VERSION = "v1"
SERVICE_NAME = "menu-backend"

# Demo deployments only: bypasses Cloudflare Access admin auth and resets data on cron.
# Never enable this on production.
DEMO_MODE = "false"
# Public URL of your R2 bucket (or a custom domain pointing at it).
R2_PUBLIC_URL = "https://pub-XXXXXXXX.r2.dev"

# Cloudflare Access — admin JWT verification.
# In Cloudflare dashboard → Zero Trust → Access → Applications → Add an
# application for this Worker. Then:
# - ACCESS_TEAM_DOMAIN = https://<your-team>.cloudflareaccess.com
# - ACCESS_AUD = (the AUD tag shown in the Access app's "Overview")
ACCESS_TEAM_DOMAIN = "https://your-team.cloudflareaccess.com"
ACCESS_AUD = "your-aud-tag-from-cloudflare-access"

# Comma-separated list of admin emails. The user's email comes from the
# Cloudflare Access JWT; it must match (case-insensitive) one of these to
# get past `requireAdmin`.
ADMIN_EMAILS = "you@example.com"

# Comma-separated list of origins allowed to hit this API.
ALLOWED_ORIGINS = "http://localhost:3000,https://your-domain.example"
# Hostname suffixes allowed over HTTPS (Pages preview deploys). Optional.
# ALLOWED_HOST_SUFFIXES = ".your-pages-project.pages.dev"

[[d1_databases]]
binding = "DB"
database_name = "menu-db"
# Run: npx wrangler d1 create menu-db  → copy the returned database_id here.
database_id = "00000000-0000-0000-0000-000000000000"
migrations_dir = "drizzle"

# Optional: enable when you have an R2 bucket for catalog snapshots / images.
# [[r2_buckets]]
# binding = "PUBLIC_MENU_BUCKET"
# bucket_name = "menu-public"
# preview_bucket_name = "menu-public"


# Optional for demo deployments: reset demo data every hour.
# [triggers]
# crons = ["0 * * * *"]
# Optional: if you wire up a queue for analytics/audit events.
# [[queues.producers]]
# binding = "EVENTS_QUEUE"
# queue = "risto-events"
